{
  "name": "@oztix/roadie-core",
  "version": "2.1.0",
  "description": "Design tokens, CSS foundation, and utilities for the Roadie Design System",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/TicketSolutionsPtyLtd/roadie"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": {
      "style": "./src/css/roadie.css",
      "default": "./src/css/roadie.css"
    },
    "./css/compiled": "./dist/roadie.compiled.css",
    "./colors": {
      "types": "./dist/colors/index.d.ts",
      "import": "./dist/colors/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src/css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf node_modules dist",
    "build": "tsdown && pnpm build:css",
    "build:quiet": "tsdown --log-level warn && pnpm build:css",
    "build:css": "tailwindcss -i src/css/roadie.css -o dist/roadie.compiled.css --content 'src/css/safelist.html'",
    "dev": "run-p dev:*",
    "dev:tsdown": "tsdown --watch --log-level warn",
    "format:check": "prettier --ignore-path ../../.prettierignore --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format": "prettier --ignore-path ../../.prettierignore --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "author": {
    "name": "Luke Brooker",
    "email": "mail@lukebrooker.com"
  },
  "license": "ISC",
  "dependencies": {
    "clsx": "2.1.1",
    "colorjs.io": "0.6.1",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.2",
    "@types/node": "24.9.2",
    "@vitejs/plugin-react": "5.1.0",
    "@vitest/coverage-v8": "4.0.4",
    "chokidar-cli": "3.0.0",
    "npm-run-all": "4.1.5",
    "tailwindcss": "4.2.2",
    "tsdown": "0.21.7",
    "vitest": "4.0.4"
  }
}
