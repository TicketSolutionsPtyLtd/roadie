{
  "name": "@oztix/roadie-components",
  "version": "2.2.0",
  "description": "React components for the Roadie Design System",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/TicketSolutionsPtyLtd/roadie"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./spot-illustrations": {
      "types": "./dist/SpotIllustration.d.ts",
      "import": "./dist/SpotIllustration.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && pnpm check:dts && pnpm check:exports",
    "build:quiet": "tsdown --log-level warn",
    "check:dts": "! grep -r 'ComponentProps<typeof' dist/*.d.ts dist/**/*.d.ts 2>/dev/null || (echo 'ERROR: dist .d.ts files contain ComponentProps<typeof> — use named prop types instead' && exit 1)",
    "check:exports": "attw --pack . --profile esm-only",
    "build:spotillustration": "node scripts/svg-to-spot-illustration.cjs",
    "clean": "rm -rf node_modules dist",
    "dev": "tsdown --watch --log-level warn",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "format": "prettier --ignore-path ../../.prettierignore --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --ignore-path ../../.prettierignore --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "size:check": "size-limit --limit"
  },
  "peerDependencies": {
    "@ark-ui/react": "^5.0.0",
    "@base-ui/react": "^1.0.0",
    "@phosphor-icons/react": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@oztix/roadie-core": "workspace:*",
    "embla-carousel": "9.0.0-rc02",
    "embla-carousel-autoplay": "9.0.0-rc02",
    "embla-carousel-react": "9.0.0-rc02"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@ark-ui/react": "5.35.0",
    "@base-ui/react": "1.3.0",
    "@phosphor-icons/react": "2.1.10",
    "@size-limit/preset-small-lib": "12.0.1",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.9.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "5.1.0",
    "@vitest/coverage-v8": "4.0.4",
    "@vitest/ui": "4.0.4",
    "class-variance-authority": "0.7.1",
    "jsdom": "27.0.1",
    "size-limit": "12.0.1",
    "svgo": "4.0.0",
    "tsdown": "0.21.7",
    "vitest": "4.0.4"
  },
  "author": {
    "name": "Luke Brooker",
    "email": "mail@lukebrooker.com"
  },
  "license": "ISC",
  "size-limit": [
    {
      "name": "Carousel",
      "path": "dist/Carousel.js",
      "limit": "5 KB",
      "ignore": [
        "react",
        "react-dom",
        "@oztix/roadie-core",
        "@phosphor-icons/react",
        "embla-carousel",
        "embla-carousel-react",
        "embla-carousel-autoplay"
      ]
    }
  ],
  "turbo": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    }
  }
}
