{
  "name": "@oztix/roadie-widgets",
  "version": "0.0.0",
  "description": "Roadie Design System widgets (core + React + Vue skins) — currently the shared cart drawer",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/TicketSolutionsPtyLtd/roadie"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./cart-drawer/core": {
      "types": "./dist/cart-drawer/core/index.d.ts",
      "import": "./dist/cart-drawer/core/index.js"
    },
    "./cart-drawer/react": {
      "types": "./dist/cart-drawer/react/index.d.ts",
      "import": "./dist/cart-drawer/react/index.js"
    },
    "./cart-drawer/vue": {
      "types": "./dist/cart-drawer/vue/index.d.ts",
      "import": "./dist/cart-drawer/vue/index.js"
    },
    "./cart-drawer/vue/style.css": "./dist/cart-drawer/vue/style.css"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --ignore-path ../../.prettierignore --write \"**/*.{ts,tsx,js,jsx,vue,json,css,md}\""
  },
  "dependencies": {
    "@oztix/roadie-core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@oztix/roadie-components": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "motion": "^12.0.0",
    "@number-flow/react": "^0.5.0",
    "react-focus-lock": "^2.13.0",
    "vue": "^3.5.0",
    "focus-trap": "^7.6.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "@oztix/roadie-components": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "motion": {
      "optional": true
    },
    "@number-flow/react": {
      "optional": true
    },
    "react-focus-lock": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "focus-trap": {
      "optional": true
    }
  },
  "devDependencies": {
    "@oztix/roadie-components": "workspace:*",
    "@oztix/roadie-core": "workspace:*",
    "@number-flow/react": "^0.5.14",
    "@testing-library/jest-dom": "6.9.1",
    "@tanstack/react-query": "^5.62.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "22.10.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "5.1.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "4.0.4",
    "@vue/test-utils": "^2.4.6",
    "focus-trap": "^7.6.5",
    "jsdom": "27.0.1",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-focus-lock": "2.13.7",
    "tsdown": "0.21.7",
    "typescript": "5.9.3",
    "vitest": "4.0.4",
    "vue": "^3.5.13",
    "vue-tsc": "~3.2.0"
  }
}
