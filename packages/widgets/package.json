{
  "name": "@oztix/roadie-widgets",
  "version": "0.0.0",
  "description": "Roadie Design System widgets (core + React + Vue skins) — currently the shared cart drawer",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/TicketSolutionsPtyLtd/roadie"
  },
  "homepage": "https://github.com/TicketSolutionsPtyLtd/roadie/tree/main/packages/widgets",
  "bugs": "https://github.com/TicketSolutionsPtyLtd/roadie/issues",
  "author": {
    "name": "Luke Brooker",
    "email": "mail@lukebrooker.com"
  },
  "license": "ISC",
  "main": "./dist/cart-drawer/core/index.js",
  "module": "./dist/cart-drawer/core/index.js",
  "types": "./dist/cart-drawer/core/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./cart-drawer/core": {
      "types": "./dist/cart-drawer/core/index.d.ts",
      "import": "./dist/cart-drawer/core/index.js"
    },
    "./cart-drawer/react": {
      "types": "./dist/cart-drawer/react/index.d.ts",
      "import": "./dist/cart-drawer/react/index.js"
    },
    "./cart-drawer/vue": {
      "types": "./dist/cart-drawer/vue/index.d.ts",
      "import": "./dist/cart-drawer/vue/index.js"
    },
    "./cart-drawer/vue/style.css": "./dist/cart-drawer/vue/style.css"
  },
  "scripts": {
    "build": "tsdown && pnpm check:dts && pnpm check:exports",
    "build:quiet": "tsdown --log-level warn",
    "check:dts": "node scripts/check-dts.mjs",
    "check:exports": "attw --pack . --profile esm-only --exclude-entrypoints ./cart-drawer/vue/style.css",
    "clean": "rm -rf node_modules dist",
    "dev": "tsdown --watch --log-level warn",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --ignore-path ../../.prettierignore --write \"**/*.{ts,tsx,js,jsx,vue,json,css,md}\"",
    "format:check": "prettier --ignore-path ../../.prettierignore --check \"**/*.{ts,tsx,js,jsx,vue,json,css,md}\"",
    "size": "size-limit",
    "size:check": "size-limit --limit"
  },
  "dependencies": {
    "@oztix/roadie-core": "workspace:*",
    "focus-trap": "^7.6.5"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@oztix/roadie-components": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "motion": "^12.0.0",
    "@number-flow/react": "^0.5.0",
    "@phosphor-icons/react": "^2.0.0",
    "react-focus-lock": "^2.13.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "@oztix/roadie-components": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "motion": {
      "optional": true
    },
    "@number-flow/react": {
      "optional": true
    },
    "@phosphor-icons/react": {
      "optional": true
    },
    "react-focus-lock": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@number-flow/react": "^0.5.14",
    "@oztix/roadie-components": "workspace:*",
    "@oztix/roadie-core": "workspace:*",
    "@phosphor-icons/react": "2.1.10",
    "@size-limit/preset-small-lib": "12.0.1",
    "@tanstack/react-query": "^5.62.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "22.10.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "5.1.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "4.0.4",
    "@vue/test-utils": "^2.4.6",
    "focus-trap": "^7.6.5",
    "jsdom": "27.0.1",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-focus-lock": "2.13.7",
    "size-limit": "12.0.1",
    "tsdown": "0.21.7",
    "typescript": "5.9.3",
    "vitest": "4.0.4",
    "vue": "^3.5.13",
    "vue-tsc": "~3.2.0"
  },
  "size-limit": [
    {
      "name": "cart-drawer/core",
      "path": "dist/cart-drawer/core/index.js",
      "limit": "1.5 KB"
    },
    {
      "name": "cart-drawer/react",
      "path": "dist/cart-drawer/react/index.js",
      "limit": "8 KB",
      "ignore": [
        "react",
        "react-dom",
        "@oztix/roadie-core",
        "@oztix/roadie-components",
        "@tanstack/react-query",
        "motion",
        "@number-flow/react",
        "react-focus-lock"
      ]
    },
    {
      "name": "cart-drawer/vue",
      "path": "dist/cart-drawer/vue/index.js",
      "limit": "8 KB",
      "ignore": [
        "vue",
        "focus-trap"
      ]
    }
  ],
  "turbo": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    }
  }
}
